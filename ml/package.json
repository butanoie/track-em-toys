{
  "name": "track-em-toys-ml",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepare-data": "tsx src/prepare-training-data.ts",
    "prepare-test-data": "tsx src/prepare-training-data.ts --test-set",
    "train": "uv run python scripts/train.py",
    "export-model": "uv run python scripts/export.py",
    "validate-model": "uv run python scripts/validate.py",
    "test": "vitest run && eslint src/ --max-warnings 0",
    "test:python": "uv run pytest scripts/tests/ -v",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --ignore-path ../.prettierignore --write .",
    "format:check": "prettier --ignore-path ../.prettierignore --check ."
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv": "^17.3.1",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.7.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18"
  }
}
