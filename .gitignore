# Xcode — keep the project file, ignore derived state
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/**/*.xcuserstate
*.moved-aside

# ML training data is large — consider Git LFS or exclude raw photos
ml/training-data/**/*.jpg
ml/training-data/**/*.png
# But track the models themselves (they're ~7MB, worth versioning)
!ml/models/*.mlmodel

# Dependencies
node_modules/

# Build output
dist/

# Test coverage
coverage/

# Environment files — never commit secrets
.env
.env.local
api/.env
api/.env.local
web/.env
web/.env.local

# Private keys
*.pem
*.p8
.DS_Store

# temp claud backups
.claude/agents.bak/
.claude/skills.bak/