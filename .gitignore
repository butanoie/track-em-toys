# Xcode — keep the project file, ignore derived state
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/**/*.xcuserstate
*.moved-aside

# iOS developer-specific config (contains OAuth client IDs)
ios/track-em-toys/Info.plist
ios/track-em-toys/*.apps.googleusercontent.com.plist

# ML training data is large — consider Git LFS or exclude raw photos
ml/training-data/**/*.jpg
ml/training-data/**/*.png
# But track the models themselves (they're ~7MB, worth versioning)
!ml/models/*.mlmodel

# Dependencies
node_modules/

# Build output
dist/

# Test coverage
coverage/

# Environment files — never commit secrets
.env
.env.local
api/.env
api/.env.local
web/.env
web/.env.local

# Private keys
*.pem
*.p8
.DS_Store

# Certs
.certs/

# Playwright
playwright-report/
test-results/
web/e2e/.auth/*.json

# temp claud backups
.claude/agents.bak/
.claude/skills.bak/

# Skill evaluation workspaces (generated test outputs, not part of the skill)
.claude/skills/*-workspace/