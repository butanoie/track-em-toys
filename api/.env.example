# Database
DATABASE_URL=postgresql://user:password@localhost:5432/trackem_dev
# Maximum number of connections in the pg pool (default: 20, range: 1–1000).
# Tune based on your PostgreSQL server's max_connections and replica count.
DB_POOL_MAX=20
# Optional: PEM-encoded CA certificate for SSL DB connections (production/staging).
# When set, the pool uses this CA for certificate chain verification instead of
# the system trust store.  Obtain from your cloud provider (e.g. Supabase, RDS).
# Inline newlines in the PEM can be encoded as literal \n for single-line storage.
# Leave unset in development/test; in production the system CAs are used if absent.
DATABASE_SSL_CA=

# JWT Signing (ES256)
# Generate key pair:
#   openssl ecparam -genkey -name prime256v1 -noout -out jwt-private.pem
#   openssl ec -in jwt-private.pem -pubout -out jwt-public.pem
JWT_PRIVATE_KEY=<ES256 PEM private key>
JWT_PUBLIC_KEY=<ES256 PEM public key>
JWT_KEY_ID=<unique key identifier for kid header>
JWT_ISSUER=track-em-toys
# Override the expected audience claim in JWTs (default: track-em-toys-api)
JWT_AUDIENCE=track-em-toys-api

# Apple Sign-In — all fields required
# Obtain from https://developer.apple.com/account/resources/
APPLE_TEAM_ID=<10-character Team ID from Apple Developer portal>
APPLE_KEY_ID=<Key ID from the .p8 Sign-In with Apple key>
APPLE_PRIVATE_KEY=<contents of .p8 file — replace newlines with \n for single-line storage>
APPLE_BUNDLE_ID=<iOS app bundle ID, e.g. com.example.trackemtoys>
APPLE_SERVICES_ID=<Services ID for web Sign-In, e.g. com.example.trackemtoys.web>

# Google Sign-In — web and iOS client IDs are required
# Obtain from https://console.cloud.google.com/apis/credentials
GOOGLE_WEB_CLIENT_ID=<Web application OAuth 2.0 client ID>
GOOGLE_IOS_CLIENT_ID=<iOS OAuth 2.0 client ID>
# Optional: Desktop OAuth 2.0 client ID for macOS native sign-in via ASWebAuthenticationSession.
# Create an OAuth 2.0 Client ID with type "Desktop app" in Google Cloud Console.
GOOGLE_DESKTOP_CLIENT_ID=

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173
# Set to true when behind a reverse proxy (nginx, Cloudflare) to trust X-Forwarded-For
TRUST_PROXY=false

# Cookie signing secret — minimum 32 characters required
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=<32-character minimum random string>

# Set to true to enable Secure flag on cookies (default: true in production)
SECURE_COOKIES=false

# Pino log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info

# Optional TLS — enable HTTPS on the API server (local dev or direct TLS termination).
# Both must be set together, or both left unset.  In local dev, reuse mkcert certs:
#   TLS_CERT_FILE=../.certs/cert.pem
#   TLS_KEY_FILE=../.certs/key.pem
TLS_CERT_FILE=
TLS_KEY_FILE=

# Photo storage — required. Directory path for uploaded catalog photos.
# Must be an absolute path. The directory must exist and be writable.
# Use an external volume for large photo collections.
PHOTO_STORAGE_PATH=/path/to/photos
# Base URL for serving photos. In dev, the API serves via @fastify/static.
# In production, use your CDN URL (e.g. https://cdn.trackem.toys/photos).
PHOTO_BASE_URL=http://localhost:3010/photos
# Maximum upload size per file in MB (default: 10, range: 1–100).
PHOTO_MAX_SIZE_MB=10

# ML export — optional. Directory path for ML training data manifests.
# When set, the "Export for ML" button in the admin search UI writes manifests here.
# Must be an absolute path. The directory will be created if it doesn't exist.
ML_EXPORT_PATH=/path/to/ml-exports

# ML model serving — optional. Directory containing trained model artifacts
# (.onnx, .onnx.data, -metadata.json) produced by ml/scripts/export.py.
# When set, GET /ml/models returns metadata for all models in this directory.
# In development, model files are also served via @fastify/static at /ml/model-files/.
ML_MODELS_PATH=/path/to/ml/models
# CDN base URL for model file downloads in production.
# Defaults to http://localhost:{PORT}/ml/model-files for local development.
ML_MODELS_BASE_URL=

# ML training data output — optional. Directory path where the ml/ prepare-data
# script writes the Create ML folder-per-class structure. Typically points to the
# private track-em-toys-data repo:
#   ML_TRAINING_DATA_PATH=/path/to/track-em-toys-data/ml/training-data
ML_TRAINING_DATA_PATH=

# Seed data source — optional.
# When unset, the ingest script and seed validation tests use the sample dataset
# at api/db/seed/sample/ (suitable for development and CI without proprietary data).
# To use the full proprietary catalog data, clone the private seed data repository
# and set this to its absolute path:
#   SEED_DATA_PATH=/path/to/track-em-toys-data/data
# The directory must mirror api/db/seed/sample/ structure:
#   reference/, characters/, appearances/, relationships/, items/
SEED_DATA_PATH=
